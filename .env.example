# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...  # public anon key (safe for browser)
SUPABASE_SERVICE_ROLE_KEY=eyJ...      # service role key (server-only, never expose)

# ─── Sanity CMS ──────────────────────────────────────────────────────────────
# Get these from: https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=sk...  # read token (or read+write for mutations)

# ─── Resend (transactional email) ────────────────────────────────────────────
# Get from: https://resend.com/api-keys
# Also verify your sending domain (onlinevgu.com) in Resend dashboard
RESEND_API_KEY=re_...

# ─── Upstash Redis (optional — API rate limiting) ────────────────────────────
# Get from: https://console.upstash.com → Create Database → REST API
# If not set, rate limiting is disabled (safe for development)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...
